{
  "manifest_version": 3,
  "name": "Markdown Viewer",
  "version": "1.1.0",
  "description": "個人用の軽量Markdownファイルビューア",
  "permissions": ["activeTab", "storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
